---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="Edson Souza">
	<Nav />
	<main class="flex flex-1">
		<div class="flex flex-col align-center justify-center">
			<h2 class="font-sans text-3xl">👋 Hi! I am</h2>
			<h1 class="font-sans text-4xl font-bold text-orange-600">Edson Souza</h1>
			<div>
				<p class="animate-pulse font-sans">Software Engineer</p>
			</div>
		</div>
	</main>
</Layout>

<style>
	:root {
		--astro-gradient: linear-gradient(0deg, #4f39fa, #da62c4);
	}

	h1 {
		margin: 2rem 0;
	}

	main {
		margin: auto;
		padding: 1em;
		max-width: 60ch;
	}
</style>
